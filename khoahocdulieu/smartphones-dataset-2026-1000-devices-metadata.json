amera_count"},{"dataType":["sc:Text"],"source":{"fileObject":{"@id":"smartprix_smartphones_april_2026.csv_fileobject"},"extract":{"column":"os"}},"@id":"smartprix_smartphones_april_2026.csv/os","@type":"cr:Field","name":"os"}],"@id":"smartprix_smartphones_april_2026.csv","@type":"cr:RecordSet","name":"smartprix_smartphones_april_2026.csv"}],"version":1,"keywords":["technique \u003E data visualization","technique \u003E data analytics","subject \u003E science and technology \u003E electronics","subject \u003E science and technology \u003E internet \u003E mobile and wireless","task \u003E classification"],"isAccessibleForFree":true,"includedInDataCatalog":{"@type":"sc:DataCatalog","name":"Kaggle","url":"https://www.kaggle.com"},"creator":{"@type":"sc:Person","name":"Showmik","url":"/showmik121","image":"https://storage.googleapis.com/kaggle-avatars/thumbnails/default-thumb.png"},"publisher":{"@type":"sc:Organization","name":"Kaggle","url":"https://www.kaggle.com/organizations/kaggle","image":"https://storage.googleapis.com/kaggle-organizations/4/thumbnail.png"},"thumbnailUrl":"https://storage.googleapis.com/kaggle-datasets-images/10168936/15861526/04358e95e23861e66c6e0606324b6fc1/dataset-card.jpeg?t=2026-04-21-18-22-40","dateModified":"2026-04-21T16:00:06.893","datePublished":"2026-04-21T16:00:06.893","@type":"sc:Dataset","name":"Latest Smartphones 2026: Price, Specs \u0026 VFM Score","url":"https://www.kaggle.com/datasets/showmik121/smartphones-dataset-2026-1000-devices/versions/1","description":"\u003E **Project by:** Showmik, CSE Student at **Hajee Mohammad Danesh Science and Technology University (HSTU)**.  \n\u003E \uD83D\uDD17 Let\u0027s connect on [LinkedIn](https://www.linkedin.com/in/ahanaf-adil-showmik-244146252?utm_source=share_via\u0026utm_content=profile\u0026utm_medium=member_android) for data-driven discussions!\n\n# Smartphones 2025-2026: The Value-for-Money Analysis \uD83D\uDCF1\n\n###Author Note: \nThis dataset is curated for researchers, data scientists, and tech enthusiasts who want to look beyond the price tag and find the true engineering marvels of 2026.\n\n###Data Source\n\nThe data was collected via web scraping from Smartprix, a leading smartphone comparison platform. Dynamic content was extracted using tools like Selenium and BeautifulSoup to ensure up-to-date and accurate information.\n\n### Dataset Highlights \n- **997\u002B Devices:** Comprehensive coverage from Budget to Ultra-Flagship.\n- **Z-Score VFM Index:** A custom-engineered metric that identifies \u0022Value Kings\u0022 by comparing specs within specific price brackets\u2014no more budget-bias!\n- Modern Hardware: Covers latest chips (Snapdragon 8 Elite, Dimensity 9400) and upcoming releases.\n- **Charging Specs:** Detailed breakdown of battery capacity vs. charging speed.\n- **Price-Catagory:** Budget,mid range,premium,flagship.\n- **Future-Ready:** Includes devices running **Android v15 and v16**.\n- **price:** Indian Rupe.\n\n### **The \u0022Secret Sauce\u0022 (Feature Engineering) \uD83D\uDEE0\uFE0F**\nI didn\u0027t just scrape the data; I refined it for Data Science:\n1. **Price Segmented Z-Score:** Calculated \u0060spec_score\u0060 deviations to find outliers in every price category.\n2. **Charging Ratio:** \u0060battery_capacity / fast_charging\u0060\u2014who really has the best power tech?\n3. **Hardware Parsing:** Extracted camera counts and OS versions from raw strings.\n\n### **Inspiration \u0026 Tasks \uD83D\uDCA1**\n- **The Premium Gap:** Does a 100k BDT phone actually offer 5x more value than a 20k BDT phone?\n- **Brand Wars:** Which brand offers the highest average \u0060spec_score\u0060 in the Mid-Range?\n- **ML Task:** Build a regression model to predict \u0060Price\u0060 with 95% accuracy.\n\n###Licensing \u0026 Usage\nLicense: Apache 2.0\n\n"}